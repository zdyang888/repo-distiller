2026-05-10 23:56:49 [DEBUG] openai._base_client: HTTP Response: POST https://generativelanguage.googleapis.com/v1beta/openai/chat/completions "200 OK" Headers([('content-type', 'application/json'), ('p3p', 'CP="This is not a P3P policy! See g.co/p3phelp for more info."'), ('vary', 'Origin'), ('vary', 'X-Origin'), ('vary', 'Referer'), ('content-encoding', 'gzip'), ('date', 'Mon, 11 May 2026 06:56:49 GMT'), ('server', 'scaffolding on HTTPServer2'), ('x-xss-protection', '0'), ('x-frame-options', 'SAMEORIGIN'), ('x-content-type-options', 'nosniff'), ('server-timing', 'gfet4t7; dur=42127'), ('set-cookie', 'NID=531=LmNKBl-9ltmonvc0-VSjZkBwJWogqJ6Aj44St21lz6rXi6utGXnb3808gIvN9LlsX_nmypYB5hx3Rd8grvbtb8Vzm_VsF9HrC3mKuSDGY3VHXMTVo_z8-v1DE3s9u2MzY1VAljEJBktd_UJXWRH-bjA0yUqM39ZD63eY3b9PS4OKYf8Ph_HnmwzSbS6OQw; expires=Tue, 10-Nov-2026 06:56:07 GMT; path=/; domain=.generativelanguage.googleapis.com; HttpOnly'), ('alt-svc', 'h3=":443"; ma=2592000,h3-29=":443"; ma=2592000'), ('expires', 'Mon, 11 May 2026 06:56:49 GMT'), ('cache-control', 'private'), ('transfer-encoding', 'chunked')])
