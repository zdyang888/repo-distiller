 2, 3], y should be [1, 2, 3, 4].\n        # Using a deterministic sequence to make this easy to check.\n        deterministic_content = "0123456789"\n        file_path = tmp_path / "deterministic.txt"\n        file_path.write_text(deterministic_content)\n\n        # block_size=5, batch_size=1 means it will always grab the first 5 tokens.\n        loader = IMiniTextDataLoader(data_path=str(file_path), block_size=5, batch_size=1)\n        # Create a mapping from char to int to verify tokenization\n        chars = sorted(list(set(deterministic_content)))\n        stoi = { ch:i for i,ch in enumerate(chars) }\n\n        x, y = loader.get_batch(\'train\')\n\n        # The first batch must be tokens for "01234" and "12345"\n        expected_x = torch.tensor([[stoi[\'0\'], stoi[\'1\'], stoi[\'2\'], stoi[\'3\'], stoi[\'4\']]], dtype=torch.long)\n        expected_y = torch.tensor([[stoi[\'1\'], stoi[\'2\'], stoi[\'3\'], stoi[\'4\'], stoi[\'5\']]], dtype=torch.long)\n\n        assert torch.equal(x, expected_x), f"Expected input x to be tokens for \'01234\', but got different values."\n        assert torch.equal(y, expected_y), f"Expected target y to be tokens for \'12345\', but got different values."\n\n\nclass TestMiniGPTModel:\n    """Unit tests for the MiniGPTModel component."""\n\n    def test_forward_pass_logits_shape(self, model: IMiniGPTModel, config: MiniGPTConfig):\n        """\n        Verifies the forward pass returns logits with the correct shape.\n        The shape should be [batch_size, block_size, vocab_size].\n        """\n        # STUDENT_HINT: Your model\'s `forward` method must return logits. The final layer\n        # of your model should be a linear layer that projects to the vocabulary size.\n        batch_size = 4\n        # Create a dummy input tensor of token indices\n        idx = torch.randint(0, config.vocab_size, (batch_size, config.block_size))\n        logits, loss = model(idx)\n\n        expected_shape = (batch_size, config.block_size, config.vocab_size)\n        assert logits.shape == expected_shape, f"Expected logits shape {expected_shape}, but got {logits.shape}"\n        assert loss is None, "Loss should be None when targets are not provided."\n\n    def test_forward_pass_loss_calculation(self, model: IMiniGPTModel, config: MiniGPTConfig):\n        """\n        Verifies that when targets are provided, the forward pass returns a valid scalar loss.\n        This checks the loss computation logic.\n        """\n        # STUDENT_HINT: In the `forward` method, if `targets` are not None, you must\n        # calculate the cross-entropy loss between your logits and the targets.\n        batch_size = 4\n        idx = torch.randint(0, config.vocab_size, (batch_size, config.block_size))\n        targets = torch.randint(0, config.vocab_size, (batch_size, config.block_size))\n\n        logits, loss = model(idx, targets)\n        assert loss is not None, "Loss should not be None when targets are provided."\n        assert isinstance(loss, torch.Tensor), f"Loss must be a torch.Tensor, but got {type(loss)}"\n        assert loss.dim() == 0, f"Loss must be a scalar (0 dimensions), but got {loss.dim()} dimensions."\n\n    def test_generate_output_shape(self, model: IMiniGPTModel, config: MiniGPTConfig):\n        """\n        Verifies that the generate method produces an output tensor of the correct length.\n        The new length should be the original length plus max_new_tokens.\n        """\n        # STUDENT_HINT: The `generate` method should loop `max_new_tokens` times,\n        # appending one new token to the input sequence in each iteration.\n        initial_context = torch.zeros((1, 5), dtype=torch.long) # A prompt of 5 tokens\n        max_new_tokens = 10\n        generated_tokens = model.generate(initial_context, max_new_tokens)\n\n        expected_length = initial_context.shape[1] + max_new_tokens\n        assert generated_tokens.shape[1] == expected_length, \\\n            f"Expected generated sequence length {expected_length}, but got {generated_tokens.shape[1]}"\n\n    def test_get_num_parameters(self, model: IMiniGPTModel):\n        """\n        Verifies that get_num_parameters returns a positive integer count.\n        This is a sanity check that the model has trainable parameters.\n        """\n        # STUDENT_HINT: This method should iterate through `self.parameters()` and sum\n        # up the number of elements for each parameter where `requires_grad` is True.\n        num_params = model.get_num_parameters()\n        assert isinstance(num_params, int), "Number of parameters must be an integer."\n        assert num_params > 0, "Model should have at least one trainable parameter."\n\n\nclass TestMiniTrainer:\n    """Unit tests for the MiniTrainer component."""\n\n    def test_evaluate_returns_float_and_restores_mode(self, trainer: IMiniTrainer):\n        """\n        Verifies that evaluate() returns a float and that the model is returned to train mode.\n        This checks the basic contract of the evaluation method.\n        """\n        # STUDENT_HINT: Your `evaluate` method should use a `torch.no_grad()` context,\n        # set the model to eval mode (`model.eval()`), and set it back to train mode\n        # (`model.train()`) before returning the average loss.\n        trainer.model.train() # Ensure model is in train mode initially\n        val_loss = trainer.evaluate(num_batches=2)\n\n        assert isinstance(val_loss, float), f"Evaluation loss must be a float, but got {type(val_loss)}."\n        assert trainer.model.training, "Model was not returned to train mode after evaluation."\n\n    def test_weights_change_after_train(self, trainer: IMiniTrainer):\n        """\n        Verifies that the model\'s weights have changed after a training step.\n        This is the most critical test to confirm that backpropagation and optimization are working.\n        """\n        # STUDENT_HINT: The `train` method must perform a forward pass, a backward\n        # pass (`loss.backward()`), and an optimizer step (`optimizer.step()`).\n        # This will update the model\'s weights.\n        initial_params = [p.clone().detach() for p in trainer.model.parameters()]\n        trainer.train(num_iterations=1)\n        final_params = [p.clone().detach() for p in trainer.model.parameters()]\n\n        # Check if at least one parameter has changed\n        params_changed = any(not torch.equal(initial, final) for initial, final in zip(initial_params, final_params))\n        assert params_changed, "Model parameters did not change after one training iteration."\n\n    def test_training_reduces_loss(self, trainer: IMiniTrainer):\n        """\n        Verifies that loss decreases over several training iterations.\n        This is a strong indicator that the training loop is implemented correctly.\n        """\n        # STUDENT_HINT: A correctly implemented training loop (data fetching, forward,\n        # backward, optimizer step) should result in a decreasing loss on a simple dataset.\n        # If loss increases or stays the same, check your loss calculation or optimizer logic.\n        initial_loss = trainer.evaluate(num_batches=5)\n        trainer.train(num_iterations=10)\n        final_loss = trainer.evaluate(num_batches=5)\n\n        assert final_loss < initial_loss, \\\n            f"Loss did not decrease after training. Initial: {initial_loss:.4f}, Final: {final_loss:.4f}"\n\n\n# --- Integration Test --------------------------------------------------------\n\n@pytest.mark.integration\ndef test_full_training_and_generation_pipeline(tmp_path: Path):\n    """\n    An end-to-end test that wires all components together.\n    It trains the model on a small dataset and verifies that the loss\n    decreases and that the model can generate coherent text.\n    """\n    # STUDENT_HINT: This test combines everything. A failure here could be in any\n    # component or the interaction between them. Use the unit test failures to\n    # pinpoint the exact location of the problem first.\n\n    # 1. Setup: Create a dummy dataset and configurations\n    dummy_text = "Peter Piper picked a peck of pickled peppers. " * 5\n    data_file = tmp_path / "integration_data.txt"\n    data_file.write_text(dummy_text)\n\n    # 2. Instantiate components\n    try:\n        data_loader = IMiniTextDataLoader(data_path=str(data_file), block_size=16, batch_size=4)\n        config = MiniGPTConfig(\n            block_size=16,\n            vocab_size=data_loader.get_vocab_size(),\n            n_layer=2,\n            n_head=2,\n            n_embd=32,\n        )\n        model = IMiniGPTModel(config)\n        trainer_config = {\'learning_rate\': 1e-2, \'device\': \'cpu\'}\n        trainer = IMiniTrainer(model, data_loader, trainer_config)\n    except Exception as e:\n        pytest.fail(f"Failed to initialize components for integration test: {e}")\n\n    # 3. Verify that training improves the model\n    initial_loss = trainer.evaluate(num_batches=5)\n    trainer.train(num_iterations=30)\n    final_loss = trainer.evaluate(num_batches=5)\n\n    assert final_loss < initial_loss, \\\n        f"Integration test failed: Loss did not decrease. Initial: {initial_loss:.4f}, Final: {final_loss:.4f}"\n\n    # 4. Verify that generation works and produces valid tokens\n    prompt = torch.zeros((1, 1), dtype=torch.long)  # Start with the first token in vocab\n    max_new_tokens = 20\n    generated_output = model.generate(prompt, max_new_tokens=max_new_tokens)\n\n    # Check output shape\n    expected_len = prompt.shape[1] + max_new_tokens\n    assert generated_output.shape == (1, expected_len), \\\n        f"Generated output has incorrect shape. Expected (1, {expected_len}), got {generated_output.shape}"\n\n    # Check if generated tokens are from the vocabulary\n    vocab_size = data_loader.get_vocab_size()\n    are_tokens_valid = torch.all(generated_output < vocab_size) and torch.all(generated_output >= 0)\n    assert are_tokens_valid, "Generated output contains tokens outside of the vocabulary range."\n\n    print(f"\\nIntegration test success! Initial loss: {initial_loss:.4f}, Final loss: {final_loss:.4f}")\n\n── Reference implementation ──\nimport torch\nimport torch.nn as nn\nfrom torch.nn import functional as F\nimport math\nfrom dataclasses import dataclass\nfrom typing import Optional, Any\n\n# Imports from the provided interfaces module.\n# The `interfaces` module is assumed to be in the same directory or in the python path.\nfrom interfaces import (\n    IMiniGPTModel as ABC_IMiniGPTModel,\n    IMiniTextDataLoader as ABC_IMiniTextDataLoader,\n    IMiniTrainer as ABC_IMiniTrainer,\n    MiniGPTConfig as BaseMiniGPTConfig,\n)\n\n# -----------------------------------------------------------------------------\n# Configuration\n# -----------------------------------------------------------------------------\n\n@dataclass\nclass MiniGPTConfig(BaseMiniGPTConfig):\n    """\n    A concrete dataclass for model hyperparameters.\n    Inherits from the base class defined in interfaces.py to ensure compatibility,\n    though in this case it\'s identical.\n    """\n    pass\n\n# -----------------------------------------------------------------------------\n# Data Loader Implementation\n# -----------------------------------------------------------------------------\n\nclass IMiniTextDataLoader(ABC_IMiniTextDataLoader):\n    """\n    A concrete implementation of the data loader interface.\n    This loader performs character-level tokenization on a text file and\n    provides batches for training and validation.\n    """\n\n    def __init__(self, data_path: str, block_size: int, batch_size: int):\n        """\n        Initializes the data loader by reading and tokenizing the text data.\n        """\n        with open(data_path, \'r\', encoding=\'utf-8\') as f:\n            text = f.read()\n\n        # Create a character-level vocabulary\n        self.chars = sorted(list(set(text)))\n        self.vocab_size = len(self.chars)\n        self.stoi = {ch: i for i, ch in enumerate(self.chars)}\n        self.itos = {i: ch for i, ch in enumerate(self.chars)}\n\n        # Tokenize the entire dataset\n        data = torch.tensor([self.stoi[c] for c in text], dtype=torch.long)\n\n        # Split into training and validation sets (90%/10%)\n        n = int(0.9 * len(data))\n        self.train_data = data[:n]\n        self.val_data = data[n:]\n\n        self.block_size = block_size\n        self.batch_size = batch_size\n\n    def get_batch(self, split: str = \'train\') -> tuple[torch.Tensor, torch.Tensor]:\n        """\n        Retrieves a single random batch of inputs and targets.\n        """\n        data = self.train_data if split == \'train\' else self.val_data\n        \n        # We need to be able to pull a chunk of size block_size + 1 because\n        # the targets (y) are shifted by one position from the inputs (x).\n        # The last possible starting index is len(data) - block_size - 1.\n        max_start_idx = len(data) - self.block_size\n        if max_start_idx <= 0:\n             raise ValueError(f"The \'{split}\' dataset (length {len(data)}) is not long enough "\n                              f"for the given block_size ({self.block_size}).")\n\n        # Randomly sample starting positions for the batch\n        ix = torch.randint(max_start_idx, (self.batch_size,))\n\n        # Create input and target tensors\n        x = torch.stack([data[i:i + self.block_size] for i in ix])\n        y = torch.stack([data[i + 1:i + self.block_size + 1] for i in ix])\n        \n        return x, y\n\n    def get_vocab_size(self) -> int:\n        """\n        Returns the size of the character vocabulary.\n        """\n        return self.vocab_size\n\n# -----------------------------------------------------------------------------\n# Core Model Implementation\n# -----------------------------------------------------------------------------\n\nclass CausalSelfAttention(nn.Module):\n    """\n    A multi-head masked self-attention layer.\n    """\n    def __init__(self, config: MiniGPTConfig):\n        super().__init__()\n        assert config.n_embd % config.n_head == 0\n        self.c_attn = nn.Linear(config.n_embd, 3 * config.n_embd)\n        self.c_proj = nn.Linear(config.n_embd, config.n_embd)\n        self.attn_dropout = nn.Dropout(config.dropout)\n        self.resid_dropout = nn.Dropout(config.dropout)\n        self.n_head = config.n_head\n        self.n_embd = config.n_embd\n        self.register_buffer("bias", torch.tril(torch.ones(config.block_size, config.block_size))\n                                     .view(1, 1, config.block_size, config.block_size))\n\n    def forward(self, x):\n        B, T, C = x.size()\n        q, k, v = self.c_attn(x).split(self.n_embd, dim=2)\n        k = k.view(B, T, self.n_head, C // self.n_head).transpose(1, 2)\n        q = q.view(B, T, self.n_head, C // self.n_head).transpose(1, 2)\n        v = v.view(B, T, self.n_head, C // self.n_head).transpose(1, 2)\n\n        att = (q @ k.transpose(-2, -1)) * (1.0 / math.sqrt(k.size(-1)))\n        att = att.masked_fill(self.bias[:, :, :T, :T] == 0, float(\'-inf\'))\n        att = F.softmax(att, dim=-1)\n        att = self.attn_dropout(att)\n        y = att @ v\n        y = y.transpose(1, 2).contiguous().view(B, T, C)\n        y = self.resid_dropout(self.c_proj(y))\n        return y\n\nclass Block(nn.Module):\n    """\n    A standard Transformer block with self-attention and a feed-forward network.\n    """\n    def __init__(self, config: MiniGPTConfig):\n        super().__init__()\n        self.ln_1 = nn.LayerNorm(config.n_embd)\n        self.attn = CausalSelfAttention(config)\n        self.ln_2 = nn.LayerNorm(config.n_embd)\n        self.mlp = nn.Sequential(\n            nn.Linear(config.n_embd, 4 * config.n_embd),\n            nn.GELU(),\n            nn.Linear(4 * config.n_embd, config.n_embd),\n            nn.Dropout(config.dropout),\n        )\n\n    def forward(self, x):\n        x = x + self.attn(self.ln_1(x))\n        x = x + self.mlp(self.ln_2(x))\n        return x\n\nclass IMiniGPTModel(ABC_IMiniGPTModel):\n    """\n    Concrete implementation of the simplified GPT model.\n    """\n    def __init__(self, config: MiniGPTConfig):\n        super().__init__()\n        self.config = config\n        \n        self.transformer = nn.ModuleDict(dict(\n            wte=nn.Embedding(config.vocab_size, config.n_embd),\n            wpe=nn.Embedding(config.block_size, config.n_embd),\n            drop=nn.Dropout(config.dropout),\n            h=nn.ModuleList([Block(config) for _ in range(config.n_layer)]),\n            ln_f=nn.LayerNorm(config.n_embd),\n        ))\n        self.lm_head = nn.Linear(config.n_embd, config.vocab_size, bias=False)\n        self.transformer.wte.weight = self.lm_head.weight\n        self.apply(self._init_weights)\n        for pn, p in self.named_parameters():\n            if pn.endswith(\'c_proj.weight\'):\n                torch.nn.init.normal_(p, mean=0.0, std=0.02 / math.sqrt(2 * config.n_layer))\n\n    def _init_weights(self, module):\n        if isinstance(module, nn.Linear):\n            torch.nn.init.normal_(module.weight, mean=0.0, std=0.02)\n            if module.bias is not None:\n                torch.nn.init.zeros_(module.bias)\n        elif isinstance(module, nn.Embedding):\n            torch.nn.init.normal_(module.weight, mean=0.0, std=0.02)\n\n    def forward(self, idx: torch.Tensor, targets: Optional[torch.Tensor] = None) -> tuple[torch.Tensor, Optional[torch.Tensor]]:\n        device = idx.device\n        b, t = idx.size()\n        assert t <= self.config.block_size, f"Input sequence length ({t}) exceeds block size ({self.config.block_size})"\n        pos = torch.arange(0, t, dtype=torch.long, device=device).unsqueeze(0)\n\n        tok_emb = self.transformer.wte(idx)\n        pos_emb = self.transformer.wpe(pos)\n        x = self.transformer.drop(tok_emb + pos_emb)\n        for block in self.transformer.h:\n            x = block(x)\n        x = self.transformer.ln_f(x)\n        logits = self.lm_head(x)\n\n        loss = None\n        if targets is not None:\n            loss = F.cross_entropy(logits.view(-1, logits.size(-1)), targets.view(-1))\n        \n        return logits, loss\n\n    def generate(self, idx: torch.Tensor, max_new_tokens: int, temperature: float = 1.0, top_k: Optional[int] = None) -> torch.Tensor:\n        self.eval() # Set model to evaluation mode for generation\n        for _ in range(max_new_tokens):\n            idx_cond = idx[:, -self.config.block_size:]\n            logits, _ = self(idx_cond)\n            logits = logits[:, -1, :] / temperature\n            if top_k is not None:\n                v, _ = torch.topk(logits, min(top_k, logits.size(-1)))\n                logits[logits < v[:, [-1]]] = -float(\'Inf\')\n            probs = F.softmax(logits, dim=-1)\n            idx_next = torch.multinomial(probs, num_samples=1)\n            idx = torch.cat((idx, idx_next), dim=1)\n        self.train() # Set model back to train mode\n        return idx\n\n    def get_num_parameters(self) -> int:\n        return sum(p.numel() for p in self.parameters() if p.requires_grad)\n\n# -----------------------------------------------------------------------------\n# Trainer Implementation\n# -----------------------------------------------------------------------------\n\nclass IMiniTrainer(ABC_IMiniTrainer):\n    """\n    Concrete implementation of the model trainer.\n    Manages the training loop, optimization, and evaluation.\n    """\n    def __init__(self, model: IMiniGPTModel, data_loader: IMiniTextDataLoader, config: dict[str, Any]):\n        self.model = model\n        self.data_loader = data_loader\n        self.config = config\n        self.device = config.get(\'device\', \'cuda\' if torch.cuda.is_available() else \'cpu\')\n        self.model.to(self.device)\n        self.optimizer = torch.optim.AdamW(\n            self.model.parameters(),\n            lr=config.get(\'learning_rate\', 1e-3),\n            weight_decay=config.get(\'weight_decay\', 0.01)\n        )\n    \n    def train(self, num_iterations: int) -> None:\n        self.model.train()\n        for _ in range(num_iterations):\n            x, y = self.data_loader.get_batch(\'train\')\n            x, y = x.to(self.device), y.to(self.device)\n            _, loss = self.model(x, y)\n            self.optimizer.zero_grad(set_to_none=True)\n            loss.backward()\n            self.optimizer.step()\n            \n    @torch.no_grad()\n    def evaluate(self, num_batches: int = 10) -> float:\n        self.model.eval()\n        losses = []\n        for _ in range(num_batches):\n            try:\n                x, y = self.data_loader.get_batch(\'val\')\n                x, y = x.to(self.device), y.to(self.device)\n                _, loss = self.model(x, y)\n                losses.append(loss.item())\n            except ValueError:\n                # This can happen if the validation set is too small.\n                # In a real scenario, we\'d handle this better, but for the\n                # test suite, we can break if we can\'t get a batch.\n                if not losses: return float(\'nan\') # No batches could be processed\n                break\n\n        avg_loss = sum(losses) / len(losses) if losses else float(\'nan\')\n        self.model.train()\n        return avg_loss\n\n── pytest failure output ──\n============================= test session starts ==============================\ncollecting ... collected 0 items / 1 error\n\n==================================== ERRORS ====================================\n______________________ ERROR collecting test_capstone.py _______________________\nImportError while importing test module \'/private/var/folders/0j/7ctkl2214rb_gpkmqz2wz_ww0000gn/T/tmpjxgxm3hy/test_capstone.py\'.\nHint: make sure your test modules/packages have valid Python names.\nTraceback:\n/Users/tsetungy/miniconda3/lib/python3.12/importlib/__