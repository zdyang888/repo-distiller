2026-05-10 22:34:53 [DEBUG] openai._base_client: HTTP Response: POST https://generativelanguage.googleapis.com/v1beta/openai/chat/completions "200 OK" Headers([('content-type', 'application/json'), ('p3p', 'CP="This is not a P3P policy! See g.co/p3phelp for more info."'), ('vary', 'Origin'), ('vary', 'X-Origin'), ('vary', 'Referer'), ('content-encoding', 'gzip'), ('date', 'Mon, 11 May 2026 05:34:53 GMT'), ('server', 'scaffolding on HTTPServer2'), ('x-xss-protection', '0'), ('x-frame-options', 'SAMEORIGIN'), ('x-content-type-options', 'nosniff'), ('server-timing', 'gfet4t7; dur=67946'), ('set-cookie', 'NID=531=TFJkCW0pwVurWwZ1WIfsK0NhFf1unldArWiiQbDTq_SO0Odbuew8Xg7-X2bdawQ2UfDQPtiDQTANdChPumZqEprEYz76X2ML8sX-OXUxdzTjj28F6mE0sTfKdJiVviU2g70dEw9In-oCQK-V61O5R8-ffKzNbWgecuOd5m0VwoHJVwGpJIiZiTnbc2L9Dwy6N410mLU0; expires=Tue, 10-Nov-2026 05:33:45 GMT; path=/; domain=.generativelanguage.googleapis.com; HttpOnly'), ('alt-svc', 'h3=":443"; ma=2592000,h3-29=":443"; ma=2592000'), ('expires', 'Mon, 11 May 2026 05:34:53 GMT'), ('cache-control', 'private'), ('transfer-encoding', 'chunked')])
