}\n        self.decoder = {}\n\n    def prepare_data(self, text: str, output_file: str) -> None:\n        """\n        Processes raw text and saves the tokenized data to a binary file.\n        """\n        chars = sorted(list(set(text)))\n        \n        # Constrain the vocabulary to the specified size\n        effective_vocab = chars[:self.vocab_size]\n        self.vocab_size = len(effective_vocab)\n\n        self.encoder = {ch: i for i, ch in enumerate(effective_vocab)}\n        self.decoder = {i: ch for i, ch in enumerate(effective_vocab)}\n\n        # Encode the entire text based on the built vocabulary\n        encoded_tokens = self.encode(text)\n\n        # Serialize and write the encoded tokens to the output file as uint16\n        token_array = np.array(encoded_tokens, dtype=np.uint16)\n        token_array.tofile(output_file)\n    \n    # Helper methods required by tests for verification\n    def encode(self, s: str) -> List[int]:\n        """Encodes a string into a list of token IDs, ignoring unknown characters."""\n        return [self.encoder[c] for c in s if c in self.encoder]\n\n    def decode(self, l: List[int]) -> str:\n        """Decodes a list of token IDs back into a string."""\n        return "".join([self.decoder.get(i, "") for i in l])\n\n\n# --- Model Helper Modules ---\n\nclass Head(nn.Module):\n    """A single head of self-attention."""\n    def __init__(self, head_size: int, n_embd: int, block_size: int):\n        super().__init__()\n        self.key = nn.Linear(n_embd, head_size, bias=False)\n        self.query = nn.Linear(n_embd, head_size, bias=False)\n        self.value = nn.Linear(n_embd, head_size, bias=False)\n        self.register_buffer(\'tril\', torch.tril(torch.ones(block_size, block_size)))\n\n    def forward(self, x: torch.Tensor) -> torch.Tensor:\n        B, T, C = x.shape\n        k = self.key(x)   # (B, T, head_size)\n        q = self.query(x) # (B, T, head_size)\n\n        # Compute attention scores\n        wei = q @ k.t