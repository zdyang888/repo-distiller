cache_block_ids) > 0, "KV cache blocks should have been allocated."\n    assert kv_cache_simulator.get_num_free_blocks() < initial_free_blocks, \\\n        "Free block count should decrease after allocation."\n\ndef test_BatchScheduler_prioritizes_running_requests(batch_scheduler):\n    """\n    Verifies that a request already in the \'RUNNING\' state is automatically\n    included in the next batch, demonstrating the principle of continuous batching.\n    """\n    # STUDENT_HINT: The `schedule` method should first iterate over its internal list\n    # of `running_requests` and add them to the new batch before considering any\n    # new pending requests.\n    running_req = Request("req-running", [1], 10)\n    running_req.status = "RUNNING"\n    batch_scheduler.running_requests[running_req.request_id] = running_req\n    \n    pending_req = Request("req-pending", [2], 10)\n    \n    batch = batch_scheduler.schedule([pending_req], max_batch_size=2)\n    \n    assert len(batch) == 2, "Batch should contain both running and new pending requests."\n    assert running_req in batch, "The already running request must be in the new batch."\n    assert pending_req in batch, "The new pending request should also be in the batch."\n    assert batch[0] is running_req, "Running requests should be prioritized (added first)."\n\ndef test_BatchScheduler_updates_status_and_frees_blocks_on_completion(batch_scheduler, kv_cache_simulator):\n    """\n    Verifies that when a request\'s status is updated to \'COMPLETED\' or \'ERROR\',\n    the scheduler correctly frees its associated KV cache blocks. This is vital\n    for preventing memory leaks.\n    """\n    # STUDENT_HINT: The `update_request_status` method must call\n    # `kv_cache_simulator.free_blocks_for_request` when the new status is\n    # "COMPLETED" or "ERROR".\n    req = Request("req-1", [1, 2], 5)\n    \n    # Manually schedule and allocate\n    batch_scheduler.schedule([req], 1)\n    assert req.status == "RUNNING"\n    assert kv_cache_simulator.get_num_free_blocks() < 100\n    \n    # Now, complete it\n    batch_scheduler.update_request_status(req, "COMPLETED")\n    \n    assert req.status == "COMPLETED", "Request status should be \'COMPLETED\'."\n    assert kv_cache_simulator.get_num_free_blocks() == 100, \\\n        "All KV cache blocks should be freed upon request completion."\n    assert req.request_id not in batch_scheduler.running_requests, \\\n        "Completed request should be removed from the running pool."\n\ndef test_BatchScheduler_handles_oom_during_token_addition(batch_scheduler):\n    """\n    Verifies that if adding a token requires a new KV block and none are free,\n    the request is marked as \'ERROR\'. This tests the scheduler\'s ability to\n    handle out-of-memory (OOM) conditions gracefully during generation.\n    """\n    # STUDENT_HINT: In `add_token_to_request`, after appending a token, check if a new\n    # block is needed. If so, try to allocate it. In the `except ValueError` block\n    # for allocation failure, call `update_request_status` to set the request to "ERROR".\n    \n    # Setup a cache with very few blocks\n    small_cache = KVCacheSimulator(total_blocks=2, block_size=4)\n    scheduler = BatchScheduler(small_cache)\n    \n    # This request will exactly fill the cache on scheduling (prompt needs 2 blocks)\n    req = Request("req-1", [1,2,3,4,5], max_tokens=10) \n    \n    # Schedule it\n    scheduler.schedule([req], 1)\n    assert req.status == "RUNNING"\n    assert small_cache.get_num_free_blocks() == 0, "Cache should be full."\n\n    # Now, add a token. This shouldn\'t require a new block yet.\n    # Prompt (5) + 1 token = 6 tokens. Needs 2 blocks. Already have 2.\n    scheduler.add_token_to_request(req, 100)\n    assert req.status == "RUNNING", "Request should still be running if no new block was needed."\n\n    # Add more tokens until a new block is required (total tokens > 8)\n    scheduler.add_token_to_request(req, 101) # Total 7\n    scheduler.add_token_to_request(req, 102) # Total 8\n    scheduler.add_token_to_request(req, 103) # Total 9, needs a 3rd block, but cache is full.\n    \n    assert req.status == "ERROR", \\\n        "Request status should be set to \'ERROR\' when block allocation fails during generation."\n\n\n# --------------------------------------------------------------------------\n# Unit Tests: MiniLLMEngine\n# --------------------------------------------------------------------------\n\ndef test_MiniLLMEngine_generate_streams_output(mini_llm_engine):\n    """\n    Verifies that `generate` returns an iterator that yields multiple string\n    chunks over time, demonstrating its streaming capability.\n    """\n    # STUDENT_HINT: The `generate` method should be a generator function (using `yield`).\n    # Inside its loop, after each `_step()` call, it should check for new tokens for\n    # the specific request and yield the decoded text.\n    prompt = "Stream this text"\n    max_tokens = 5\n    \n    output_chunks = []\n    generator = mini_llm_engine.generate(prompt, max_tokens=max_tokens)\n    \n    for chunk in generator:\n        output_chunks.append(chunk)\n\n    assert len(output_chunks) > 0, "The generator should yield at least one chunk of text."\n    full_output = "".join(output_chunks)\n    # The mock model just increments, so output is not alphabetic. We just check length.\n    assert len(full_output) == max_tokens, \\\n        f"Expected total output length of {max_tokens}, but got {len(full_output)}"\n\ndef test_MiniLLMEngine_generate_produces_correct_number_of_tokens(mini_llm_engine):\n    """\n    Verifies that the complete output from the `generate` iterator corresponds\n    to the number of tokens specified by `max_tokens`.\n    """\n    # STUDENT_HINT: The completion condition in your engine\'s step logic or\n    # generate loop must check `len(req.output_tokens) >= req.max_tokens`\n    # to correctly terminate generation for a request.\n    prompt = "Generate exactly 8 tokens"\n    max_tokens = 8\n    \n    output = "".join(list(mini_llm_engine.generate(prompt, max_tokens=max_tokens)))\n    \n    # Simple tokenizer is 1 char per token\n    assert len(output) == max_tokens, \\\n        f"Expected to generate {max_tokens} tokens, but got {len(output)}."\n\ndef test_MiniLLMEngine_raises_error_on_oom(kv_cache_simulator):\n    """\n    Verifies that the `generate` method raises a RuntimeError if the engine runs\n    out of memory and the request is aborted.\n    """\n    # STUDENT_HINT: In the `generate` method, after the main loop, check if the\n    # final request status is "ERROR". If it is, raise a RuntimeError.\n    \n    # Engine with only enough memory for one request\'s prompt\n    engine = MiniLLMEngine(total_kv_blocks=2, kv_block_size=8, max_batch_size=1)\n    \n    prompt = "This prompt is long enough to use all memory" # Needs 2 blocks\n    max_tokens = 5 # Generation will require more blocks\n    \n    with pytest.raises(RuntimeError, match="failed with status: ERROR"):\n        # Consume the generator to trigger the execution and the error\n        "".join(list(engine.generate(prompt, max_tokens=max_tokens)))\n\n\n# --------------------------------------------------------------------------\n# Integration Test\n# --------------------------------------------------------------------------\n\n@pytest.mark.integration\ndef test_engine_handles_concurrent_requests_with_continuous_batching():\n    """\n    Submits multiple concurrent inference requests to the MiniLLMEngine and\n    verifies that all requests complete successfully, demonstrating the\n    system\'s ability to handle load through continuous batching.\n    """\n    # STUDENT_HINT: This tests the whole system. A failure here could be anywhere,\n    # but it likely relates to how components interact. Check that the `_step`\n    # method correctly orchestrates `schedule`, `run_forward_pass`, and state updates.\n    # Ensure thread safety if you use shared state beyond what\'s provided.\n\n    engine = MiniLLMEngine(total_kv_blocks=50, kv_block_size=4, max_batch_size=4)\n    prompts = [\n        "Hello, world",\n        "How are you",\n        "What is vLLM",\n        "Tell me a story",\n        "Python is great",\n        "Artificial intelligence is",\n        "Quantum computing will change",\n        "The quick brown fox jumps",\n    ]\n    max_tokens_per_request = 10\n    # Use a thread-safe dictionary for results\n    results = {}\n    lock = threading.Lock()\n\n    def run_inference(prompt, req_id):\n        full_output = []\n        status = "ERROR"\n        try:\n            for token_chunk in engine.generate(prompt, max_tokens=max_tokens_per_request):\n                full_output.append(token_chunk)\n            status = "COMPLETED"\n        except RuntimeError:\n            pass # Status remains ERROR\n        finally:\n            with lock:\n                results[req_id] = ("".join(full_output), status)\n\n    threads = []\n    for i, prompt in enumerate(prompts):\n        thread = threading.Thread(target=run_inference, args=(prompt, f"req_{i}"))\n        threads.append(thread)\n        thread.start()\n        # Small sleep to stagger request submission slightly, simulating real-world usage\n        time.sleep(0.001)\n\n    for thread in threads:\n        thread.join()\n\n    # --- Verification ---\n    \n    # 1. Success Metric: All requests should have completed.\n    completed_count = sum(1 for _, status in results.values() if status == "COMPLETED")\n    assert completed_count == len(prompts), \\\n        f"Expected all {len(prompts)} requests to complete, but only {completed_count} did. Results: {results}"\n    \n    # 2. Expected Output Check: Each completed request has the correct number of tokens.\n    for req_id, (output, status) in results.items():\n        if status == "COMPLETED":\n            output_len = len(output)\n            assert output_len == max_tokens_per_request, \\\n                f"Request {req_id} should have generated {max_tokens_per_request} tokens, but got {output_len}."\n\n── Reference implementation ──\nfrom collections import deque\nimport threading\nimport time\nfrom abc import ABC, abstractmethod\nfrom typing import Iterator, Any, Optional\n\n# --------------------------------------------------------------------------\n# Interfaces and Data Structures (as provided in the problem description)\n# --------------------------------------------------------------------------\n\nclass Request:\n    """\n    A data class representing a single inference request.\n\n    This class holds all state associated with a request as it moves through\n    the system, from pending to running to completion.\n    """\n\n    def __init__(self, request_id: str, prompt_tokens: list[int], max_tokens: int):\n        """\n        Initializes a new inference Request.\n\n        Args:\n            request_id: A unique identifier for the request.\n            prompt_tokens: The list of token IDs for the input prompt.\n            max_tokens: The maximum number of tokens to generate for this request.\n        """\n        self.request_id: str = request_id\n        self.prompt_tokens: list[int] = prompt_tokens\n        self.output_tokens: list[int] = []\n        self.status: str = "PENDING"  # PENDING, RUNNING, COMPLETED, ERROR\n        self.max_tokens: int = max_tokens\n        self.kv_cache_block_ids: list[int] = []  # Physically allocated blocks\n\n\nclass SimpleTokenizer:\n    """A simple, concrete tokenizer for demonstration purposes."""\n\n    def encode(self, text: str) -> list[int]:\n        """Encodes a string into a list of token IDs (ASCII values)."""\n        return [ord(c) for c in text if c.isalpha() or c.isspace()]\n\n    def decode(self, tokens: list[int]) -> str:\n        """Decodes a list of token IDs back into a string."""\n        return "".join([chr(t) for t in tokens])\n\n\nclass IRequestQueue(ABC):\n    @abstractmethod\n    def add_request(self, prompt: str, max_tokens: int) -> Request:\n        raise NotImplementedError\n\n    @abstractmethod\n    def get_pending_requests(self) -> list[Request]:\n        raise NotImplementedError\n\n    @abstractmethod\n    def get_request(self, request_id: str) -> Optional[Request]:\n        raise NotImplementedError\n\n    @abstractmethod\n    def remove_request(self, request_id: str) -> None:\n        raise NotImplementedError\n\n\nclass IKVCacheSimulator(ABC):\n    @abstractmethod\n    def allocate_blocks(self, request_id: str, num_blocks: int) -> list[int]:\n        raise NotImplementedError\n\n    @abstractmethod\n    def free_blocks_for_request(self, request_id: str) -> None:\n        raise NotImplementedError\n\n    @abstractmethod\n    def get_num_free_blocks(self) -> int:\n        raise NotImplementedError\n\n\nclass IModelRunner(ABC):\n    @abstractmethod\n    def run_forward_pass(self, batch_requests: list[Request]) -> dict[str, int]:\n        raise NotImplementedError\n\n\nclass IBatchScheduler(ABC):\n    @abstractmethod\n    def schedule(self, pending_requests: list[Request], max_batch_size: int) -> list[Request]:\n        raise NotImplementedError\n\n    @abstractmethod\n    def update_request_status(self, request: Request, new_status: str) -> None:\n        raise NotImplementedError\n\n    @abstractmethod\n    def add_token_to_request(self, request: Request, new_token_id: int) -> None:\n        raise NotImplementedError\n\n\nclass IMiniLLMEngine(ABC):\n    @abstractmethod\n    def generate(self, prompt: str, max_tokens: int = 16) -> Iterator[str]:\n        raise NotImplementedError\n\n# --------------------------------------------------------------------------\n# Concrete Implementations\n# --------------------------------------------------------------------------\n\nclass RequestQueue(IRequestQueue):\n    def __init__(self, tokenizer: SimpleTokenizer):\n        self._tokenizer = tokenizer\n        self._requests: dict[str, Request] = {}\n        self._pending_queue: deque[str] = deque()\n        self._next_id = 0\n        self._lock = threading.Lock()\n\n    def add_request(self, prompt: str, max_tokens: int) -> Request:\n        with self._lock:\n            request_id = f"req-{self._next_id}"\n            self._next_id += 1\n            prompt_tokens = self._tokenizer.encode(prompt)\n            request = Request(request_id, prompt_tokens, max_tokens)\n            self._requests[request_id] = request\n            self._pending_queue.append(request_id)\n            return request\n\n    def get_pending_requests(self) -> list[Request]:\n        pending_requests = []\n        for req_id in list(self._pending_queue):\n            req = self._requests.get(req_id)\n            if req and req.status == "PENDING":\n                pending_requests.append(req)\n        return pending_requests\n\n    def get_request(self, request_id: str) -> Optional[Request]:\n        return self._requests.get(request_id)\n\n    def remove_request(self, request_id: str) -> None:\n        with self._lock:\n            if request_id in self._requests:\n                del self._requests[request_id]\n            try:\n                # O(N) but necessary for cleanup if the request was never scheduled.\n                self._pending_queue.remove(request_id)\n            except ValueError:\n                # This is expected if the request was already processed.\n                pass\n\nclass KVCacheSimulator(IKVCacheSimulator):\n    def __init__(self, total_blocks: int, block_size: int):\n        self.total_blocks = total_blocks\n        self.block_size = block_size\n        self.free_blocks: list[int] = list(range(total_blocks))\n        self.allocated_blocks: dict[str, list[int]] = {}\n\n    def allocate_blocks(self, request_id: str, num_blocks: int) -> list[int]:\n        if self.get_num_free_blocks() < num_blocks:\n            raise ValueError("Not enough free KV cache blocks")\n        \n        allocated = [self.free_blocks.pop(0) for _ in range(num_blocks)]\n        \n        # Append blocks to the request\'s existing allocation.\n        self.allocated_blocks.setdefault(request_id, []).extend(allocated)\n        \n        return allocated\n\n    def free_blocks_for_request(self, request_id: str) -> None:\n        if request_id in self.allocated_blocks:\n            blocks_to_free = self.allocated_blocks.pop(request_id)\n            self.free_blocks.extend(blocks_to_free)\n            # Sorting ensures deterministic behavior for tests.\n            self.free_blocks.sort()\n\n    def get_num_free_blocks(self) -> int:\n        return len(self.free_blocks)\n\nclass MockModelRunner(IModelRunner):\n    def __init__(self, vocab_size: int = 32000):\n        self.vocab_size = vocab_size\n        # A simple counter for deterministic token generation.\n        self.mock_token_counter = 0\n\n    def run_forward_pass(self, batch_requests: list[Request]) -> dict[str, int]:\n        generated_tokens = {}\n        for req in batch_requests:\n            # Generate a token ID that is always valid (> 0, < vocab_size).\n            next_token_id = (self.mock_token_counter % (self.vocab_size - 1)) + 1\n            self.mock_token_counter += 1\n            generated_tokens[req.request_id] = next_token_id\n        return generated_tokens\n\nclass BatchScheduler(IBatchScheduler):\n    def __init__(self, kv_cache_simulator: IKVCacheSimulator):\n        self.kv_cache_simulator = kv_cache_simulator\n        self.running_requests: dict[str, Request] = {}\n\n    def schedule(self, pending_requests: list[Request], max_batch_size: int) -> list[Request]:\n        batch: list[Request] = []\n\n        # 1. Prioritize currently running requests (continuous batching).\n        for req in list(self.running_requests.values()):\n            if req.status == "RUNNING":\n                batch.append(req)\n\n        # 2. Add new pending requests if there\'s space and memory.\n        for req in pending_requests:\n            if len(batch) >= max_batch_size:\n                break\n            \n            block_size = self.kv_cache_simulator.block_size\n            blocks_needed = (len(req.prompt_tokens) + block_size - 1) // block_size\n            \n            if self.kv_cache_simulator.get_num_free_blocks() >= blocks_needed:\n                try:\n                    allocated_blocks = self.kv_cache_simulator.allocate_blocks(req.request_id, blocks_needed)\n                    req.kv_cache_block_ids = allocated_blocks\n                    req.status = "RUNNING"\n                    self.running_requests[req.request_id] = req\n                    batch.append(req)\n                except ValueError:\n                    # Not enough blocks, skip for now.\n                    pass\n        \n        return batch\n\n    def update_request_status(self, request: Request, new_status: str) -> None:\n        request.status = new_status\n        if new_status in ("COMPLETED", "ERROR"):\n            self.kv_cache_simulator.free_blocks_for_request(request.request_id)\n            if request.request_id in self.running_requests:\n                del self.running_requests[request.request_id]\n\n    def add_token_to_request(self, request: Request, new_token_id: int) -> None:\n        request.output_tokens.append(new_token_id)\n        \n        total_tokens = len(request.prompt_tokens) + len(request.output_tokens)\n        block_size = self.kv_cache_simulator.block_size\n        blocks_needed = (total_tokens + block_size - 1) // block_size\n        \n        if blocks_needed > len(request.kv_cache_block_ids):\n            num_new_blocks = blocks_needed - len(request.kv_cache_block_ids)\n            try:\n                new_blocks = self.kv_cache_simulator.allocate_blocks(request.request_id, num_new_blocks)\n                request.kv_cache_block_ids.extend(new_blocks)\n            except ValueError:\n                # Out of memory during generation.\n                self.update_request_status(request, "ERROR")\n\nclass MiniLLMEngine(IMiniLLMEngine):\n    def __init__(self, total_kv_blocks: int = 100, kv_block_size: int = 4, max_batch_size: int = 4):\n        self.tokenizer = SimpleTokenizer()\n        self.request_queue = RequestQueue(self.tokenizer)\n        self.kv_cache_simulator = KVCacheSimulator(total_kv_blocks, kv_block_size)\n        self.model_runner = MockModelRunner(vocab_size=128) # Fits ASCII for SimpleTokenizer\n        self.scheduler = BatchScheduler(self.kv_cache_simulator)\n        self.max_batch_size = max_batch_size\n        self._request_outputs: dict[str, deque[int]] = {}\n        self._engine_lock = threading.Lock()\n\n    def _step(self):\n        with self._engine_lock:\n            pending_requests = self.request_queue.get_pending_requests()\n            \n            batch = self.scheduler.schedule(pending_requests, self.max_batch_size)\n            \n            if not batch:\n                return\n\n            generated_tokens = self.model_runner.run_forward_pass(batch)\n\n            for req in batch:\n                if req.status == "RUNNING" and req.request_id in generated_tokens:\n                    token_id = generated_tokens[req.request_id]\n                    self.scheduler.add_token_to_request(req, token_id)\n\n                    # Buffer output for streaming.\n                    self._request_outputs.setdefault(req.request_id, deque()).append(token_id)\n                    \n                    # Check for completion after token is added.\n                    if req.status == "RUNNING" and len(req.output_tokens) >= req.max_tokens:\n                        self.scheduler.update_request_status(req, "COMPLETED")\n\n                if req.status in ("COMPLETED", "ERROR"):\n                    self.request_queue.remove_request(req.request_id)\n\n    def generate(self, prompt: str, max_tokens: int = 16) -> Iterator[str]:\n        request = self.request_queue.add_request(prompt, max_tokens)\n        request_id = request.request_id\n        \n        last_output_len = 0\n        while request.status not in ("COMPLETED", "ERROR"):\n            self._step()\n            \n            if request_id in self._request_outputs:\n                current_output_tokens = list(self._request_outputs[request_id])\n                if len(current_output_tokens) > last_output_len:\n                    new_tokens = current_output_tokens[last_output_len:]\n                    yield self.tokenizer.decode(new_tokens)\n                    last_output_len = len(current_output_tokens)\n            \n            # Yield control to allow other threads/requests to be processed.\n            time.sleep(0.001)\n        \n        # Yield any remaining tokens generated in the final step.\n        if request_id in self._request_outputs:\n            current_output_tokens = list(self._request_outputs[request_id])\n            if len(current_output_tokens) > last_output_len:\n                new_tokens = current_output_tokens[last_output_len:]\n                yield self.tokenizer.decode(new_tokens)\n        \n        final_status = request.status\n        final_output_tokens = list(self._request_outputs.get(request_id, []))\n\n        # Cleanup internal state for this request.\n        if request_id in self._request_outputs:\n            del self._request_outputs[request_id]\n\n        if final_status == "ERROR":\n            decoded_output = self.tokenizer.decode(final_output_tokens)\n            raise RuntimeError(f"Request {request_id} failed with status: ERROR. Output: {decoded_output}")\n\n── pytest failure output ──\nValidation timed out (exceeded 120s)\n\nCommon causes:\n- Test assumes specific implementation detail not in the interface\n- Test uses wrong expected value\n- Test calls method with wrong signature\n- Integration test requires setup that the reference impl doesn\'t satisfy\n\nFix the tests. Keep them rigorous (must catch real implementation bugs) but make them\npass against this correct reference. Output ONLY