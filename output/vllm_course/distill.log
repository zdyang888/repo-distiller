2026-05-10 23:56:17 [DEBUG] openai._base_client: HTTP Response: POST https://generativelanguage.googleapis.com/v1beta/openai/chat/completions "200 OK" Headers([('content-type', 'application/json'), ('p3p', 'CP="This is not a P3P policy! See g.co/p3phelp for more info."'), ('vary', 'Origin'), ('vary', 'X-Origin'), ('vary', 'Referer'), ('content-encoding', 'gzip'), ('date', 'Mon, 11 May 2026 06:56:17 GMT'), ('server', 'scaffolding on HTTPServer2'), ('x-xss-protection', '0'), ('x-frame-options', 'SAMEORIGIN'), ('x-content-type-options', 'nosniff'), ('server-timing', 'gfet4t7; dur=51137'), ('set-cookie', 'NID=531=FRNej77FqWwgRkQ_CS3bi8UPW6PfkHTgRjCnvR2h5NqQGgzy9fM4xH9LJsgaQzVCuPm5erL5q9lOwtArpwLmzabJXhy6Gcmg0wx2Hgtysb6u5MmB9XrZNlqEXSQgdeAdnBwe7u-3MXFs2G8w8HnJ3RsASwP5hAruU3oPHZyCkxFsnQ-7nRxZEjFWMaThHzE; expires=Tue, 10-Nov-2026 06:55:25 GMT; path=/; domain=.generativelanguage.googleapis.com; HttpOnly'), ('alt-svc', 'h3=":443"; ma=2592000,h3-29=":443"; ma=2592000'), ('expires', 'Mon, 11 May 2026 06:56:17 GMT'), ('cache-control', 'private'), ('transfer-encoding', 'chunked')])
