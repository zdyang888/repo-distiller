anagement and cleanup after a\n    request is finished.\n    """\n    # STUDENT_HINT: Ensure `get_request` correctly looks up by ID and that `remove_request`\n    # cleans up the request from your internal data structures.\n    req = request_queue.add_request("to be removed", max_tokens=1)\n    \n    # Test retrieval\n    retrieved_req = request_queue.get_request(req.request_id)\n    assert retrieved_req is not None, "get_request should find an existing request by its ID."\n    assert retrieved_req.request_id == req.request_id\n    \n    # Test removal\n    retrieved_req.status = "COMPLETED" # Removal might depend on status\n    request_queue.remove_request(req.request_id)\n    \n    assert request_queue.get_request(req.request_id) is None, \\\n        "get_request should return None for a removed request ID."\n\n\n# --------------------------------------------------------------------------\n# Unit Tests: KVCacheSimulator\n# --------------------------------------------------------------------------\n\ndef test_KVCacheSimulator_allocates_and_reduces_free_blocks(kv_cache_simulator):\n    """\n    Verifies that allocating blocks correctly reduces the number of available\n    free blocks and returns the requested number of unique block IDs. This is\n    the core function for memory provisioning.\n    """\n    # STUDENT_HINT: In `allocate_blocks`, make sure you are removing the allocated\n    # block IDs from your list of free blocks and updating the count.\n    initial_free_blocks = kv_cache_simulator.get_num_free_blocks()\n    num_to_allocate = 5\n    \n    allocated_ids = kv_cache_simulator.allocate_blocks("req-1", num_to_allocate)\n    \n    assert len(allocated_ids) == num_to_allocate, "Should allocate the exact number of requested blocks."\n    assert len(set(allocated_ids)) == num_to_allocate, "Allocated block IDs must be unique."\n    \n    expected_free_blocks = initial_free_blocks - num_to_allocate\n    actual_free_blocks = kv_cache_simulator.get_num_free_blocks()\n    assert actual_free_blocks == expected_free_blocks, \\\n        f"Expected {expected_free_blocks} free blocks, but got {actual_free_blocks}"\n\ndef test_KVCacheSimulator_frees_and_restores_free_blocks(kv_cache_simulator):\n    """\n    Verifies that freeing blocks associated with a request ID returns them to\n    the free pool, making them available for future allocations. This is critical\n    for memory recycling.\n    """\n    # STUDENT_HINT: `free_blocks_for_request` needs to find all blocks for a\n    # request_id, add them back to the free pool, and remove the request from tracking.\n    initial_free_blocks = kv_cache_simulator.get_num_free_blocks()\n    \n    # Allocate some blocks\n    kv_cache_simulator.allocate_blocks("req-1", 10)\n    assert kv_cache_simulator.get_num_free_blocks() == initial_free_blocks - 10\n    \n    # Free them\n    kv_cache_simulator.free_blocks_for_request("req-1")\n    \n    final_free_blocks = kv_cache_simulator.get_num_free_blocks()\n    assert final_free_blocks == initial_free_blocks, \\\n        f"Expected free blocks to be restored to {initial_free_blocks}, got {final_free_blocks}"\n\ndef test_KVCacheSimulator_raises_error_on_insufficient_blocks():\n    """\n    Verifies that attempting to allocate more blocks than are available raises\n    a ValueError. This prevents overallocation and signals memory pressure\n    to the scheduler.\n    """\n    # STUDENT_HINT: Before allocating, `allocate_blocks` should check if the number\n    # of requested blocks is greater than the number of available free blocks.\n    cache = KVCacheSimulator(total_blocks=5, block_size=4)\n    \n    # This should succeed\n    cache.allocate_blocks("req-1", 3)\n    \n    # This should fail\n    with pytest.raises(ValueError, match="Not enough free KV cache blocks"):\n        cache.allocate_blocks("req-2", 3)\n    \n    assert cache.get_num_free_blocks() == 2, \\\n        "The number of free blocks should not change after a failed allocation."\n\n\n# --------------------------------------------------------------------------\n# Unit Tests: MockModelRunner\n# --------------------------------------------------------------------------\n\ndef test_MockModelRunner_returns_token_for_each_request(mock_model_runner):\n    """\n    Verifies that the model runner\'s forward pass returns a dictionary\n    containing a new token ID for every request in the input batch. This\n    ensures the model processes the entire batch as expected.\n    """\n    # STUDENT_HINT: The `run_forward_pass` method should loop through `batch_requests`\n    # and generate a unique token ID for each one, returning them in a dictionary.\n    requests = [\n        Request("req-1", [10], 10),\n        Request("req-2", [20], 10),\n        Request("req-3", [30], 10),\n    ]\n    \n    generated_tokens = mock_model_runner.run_forward_pass(requests)\n    \n    assert isinstance(generated_tokens, dict), "Output should be a dictionary."\n    assert len(generated_tokens) == len(requests), \\\n        f"Expected {len(requests)} generated tokens, but got {len(generated_tokens)}."\n    \n    for req in requests:\n        assert req.request_id in generated_tokens, \\\n            f"Missing generated token for request ID {req.request_id}"\n\ndef test_MockModelRunner_generates_valid_token_ids\n\n── Reference implementation ──\nimport time\nfrom collections import deque\nfrom typing import Iterator\n\nfrom interfaces import (\n    Request,\n    SimpleTokenizer,\n    IRequestQueue,\n    IKVCacheSimulator,\n    IModelRunner,\n    IBatchScheduler,\n    IMiniLLMEngine,\n)\n\n\nclass RequestQueue(IRequestQueue):\n    """\n    Manages incoming inference requests, holding them until they can be processed.\n    """\n\n    def __init__(self, tokenizer: SimpleTokenizer):\n        self._requests: dict[str, Request] = {}\n        self.tokenizer = tokenizer\n        self._request_counter = 0\n\n    def add_request(self, prompt: str, max_tokens: int) -> Request:\n        """\n        Tokenizes a prompt and adds it as a new request to the queue.\n        """\n        self._request_counter += 1\n        request_id = f"req-{self._request_counter}"\n        prompt_tokens = self.tokenizer.encode(prompt)\n        request = Request(request_id, prompt_tokens, max_tokens)\n        self._requests[request_id] = request\n        return request\n\n    def get_pending_requests(self) -> list[Request]:\n        """\n        Retrieves all requests that are currently in the \'PENDING\' state.\n        """\n        return [req for req in self._requests.values() if req.status == "PENDING"]\n\n    def get_request(self, request_id: str) -> Request | None:\n        """\n        Retrieves a specific request by its ID.\n        """\n        return self._requests.get(request_id)\n\n    def remove_request(self, request_id: str) -> None:\n        """\n        Removes a completed or failed request from the internal tracking.\n        """\n        if request_id in self._requests:\n            del self._requests[request_id]\n\n\nclass KVCacheSimulator(IKVCacheSimulator):\n    """\n    Manages the allocation and deallocation of fixed-size KV cache blocks.\n    """\n\n    def __init__(self, total_blocks: int, block_size: int):\n        self.total_blocks = total_blocks\n        self.block_size = block_size\n        self.free_blocks = deque(range(total_blocks))\n        self.allocated_blocks: dict[str, list[int]] = {}\n\n    def allocate_blocks(self, request_id: str, num_blocks: int) -> list[int]:\n        """\n        Allocates a specified number of KV cache blocks for a given request.\n        """\n        if self.get_num_free_blocks() < num_blocks:\n            raise ValueError("Not enough free KV cache blocks")\n\n        newly_allocated = []\n        for _ in range(num_blocks):\n            newly_allocated.append(self.free_blocks.popleft())\n\n        if request_id not in self.allocated_blocks:\n            self.allocated_blocks[request_id] = []\n        self.allocated_blocks[request_id].extend(newly_allocated)\n\n        return newly_allocated\n\n    def free_blocks_for_request(self, request_id: str) -> None:\n        """\n        Returns all blocks allocated to a request back to the free pool.\n        """\n        if request_id in self.allocated_blocks:\n            blocks_to_free = self.allocated_blocks.pop(request_id)\n            self.free_blocks.extend(blocks_to_free)\n            # Sorting ensures deterministic behavior for tests\n            self.free_blocks = deque(sorted(list(self.free_blocks)))\n\n    def get_num_free_blocks(self) -> int:\n        """\n        Returns the total number of currently available KV cache blocks.\n        """\n        return len(self.free_blocks)\n\n\nclass MockModelRunner(IModelRunner):\n    """\n    Simulates an LLM\'s forward pass for a batch of requests.\n    """\n\n    def __init__(self, vocab_size: int = 128):\n        self.vocab_size = vocab_size\n        self.mock_token_counter = 0\n\n    def run_forward_pass(self, batch_requests: list[Request]) -> dict[str, int]:\n        """\n        Executes a single forward pass for a batch of requests.\n        """\n        generated_tokens = {}\n        for req in batch_requests:\n            # Simple, deterministic token generation to cycle through vocab\n            next_token_id = (self.mock_token_counter % (self.vocab_size - 1)) + 1\n            self.mock_token_counter += 1\n            generated_tokens[req.request_id] = next_token_id\n        return generated_tokens\n\n\nclass BatchScheduler(IBatchScheduler):\n    """\n    Prioritizes, batches requests, and orchestrates KV cache management.\n    """\n\n    def __init__(self, kv_cache_simulator: IKVCacheSimulator):\n        self.kv_cache_simulator = kv_cache_simulator\n        self.running_requests: dict[str, Request] = {}\n\n    def schedule(self, pending_requests: list[Request], max_batch_size: int) -> list[Request]:\n        """\n        Creates a new batch for the next model forward pass.\n        """\n        batch: list[Request] = []\n\n        # 1. Prioritize currently running requests (continuous batching)\n        running_reqs_to_process = sorted(\n            [req for req in self.running_requests.values() if req.status == "RUNNING"],\n            key=lambda r: r.request_id\n        )\n        batch.extend(running_reqs_to_process)\n\n        # 2. Try to add new pending requests\n        sorted_pending = sorted(pending_requests, key=lambda r: r.request_id)\n\n        for req in sorted_pending:\n            if len(batch) >= max_batch_size:\n                break\n\n            prompt_len = len(req.prompt_tokens)\n            block_size = self.kv_cache_simulator.block_size\n            blocks_needed = (prompt_len + block_size - 1) // block_size if prompt_len > 0 else 1\n\n            if self.kv_cache_simulator.get_num_free_blocks() >= blocks_needed:\n                try:\n                    allocated_blocks = self.kv_cache_simulator.allocate_blocks(\n                        req.request_id, blocks_needed\n                    )\n                    req.kv_cache_block_ids = allocated_blocks\n                    req.status = "RUNNING"\n                    self.running_requests[req.request_id] = req\n                    batch.append(req)\n                except ValueError:\n                    continue\n        return batch\n\n    def update_request_status(self, request: Request, new_status: str) -> None:\n        """\n        Updates the status of a request and performs associated cleanup.\n        """\n        request.status = new_status\n        if new_status in ("COMPLETED", "ERROR"):\n            self.kv_cache_simulator.free_blocks_for_request(request.request_id)\n            if request.request_id in self.running_requests:\n                del self.running_requests[request.request_id]\n\n    def add_token_to_request(self, request: Request, new_token_id: int) -> None:\n        """\n        Appends a newly generated token to a request\'s output.\n        """\n        request.output_tokens.append(new_token_id)\n\n        total_tokens = len(request.prompt_tokens) + len(request.output_tokens)\n        current_blocks = len(request.kv_cache_block_ids)\n        block_size = self.kv_cache_simulator.block_size\n        blocks_needed = (total_tokens + block_size - 1) // block_size if total_tokens > 0 else 1\n\n        if blocks_needed > current_blocks:\n            try:\n                num_new_blocks = blocks_needed - current_blocks\n                new_blocks = self.kv_cache_simulator.allocate_blocks(\n                    request.request_id, num_new_blocks\n                )\n                request.kv_cache_block_ids.extend(new_blocks)\n            except ValueError:\n                self.update_request_status(request, "ERROR")\n\n\nclass MiniLLMEngine(IMiniLLMEngine):\n    """\n    The top-level class that integrates all components for end-to-end inference.\n    """\n\n    def __init__(self, total_kv_blocks: int = 100, kv_block_size: int = 4, max_batch_size: int = 4):\n        self.tokenizer = SimpleTokenizer()\n        self.request_queue = RequestQueue(self.tokenizer)\n        self.kv_cache_simulator = KVCacheSimulator(total_blocks, kv_block_size)\n        self.model_runner = MockModelRunner(vocab_size=128)\n        self.scheduler = BatchScheduler(self.kv_cache_simulator)\n        self.max_batch_size = max_batch_size\n        self._request_outputs: dict[str, deque[int]] = {}\n\n    def _step(self):\n        """Performs one iteration of scheduling, model execution, and state update."""\n        pending = self.request_queue.get_pending_requests()\n        batch = self.scheduler.schedule(pending, self.max_batch_size)\n\n        if not batch:\n            return\n\n        generated_tokens = self.model_runner.run_forward_pass(batch)\n\n        for req in batch:\n            if req.status != "RUNNING":\n                continue\n\n            if req.request_id in generated_tokens:\n                token_id = generated_tokens[req.request_id]\n                self.scheduler.add_token_to_request(req, token_id)\n\n                if req.status == "RUNNING":\n                    self._request_outputs[req.request_id].append(token_id)\n                    if len(req.output_tokens) >= req.max_tokens:\n                        self.scheduler.update_request_status(req, "COMPLETED")\n\n            if req.status in ("COMPLETED", "ERROR"):\n                self.request_queue.remove_request(req.request_id)\n\n    def generate(self, prompt: str, max_tokens: int = 16) -> Iterator[str]:\n        """\n        Generates text for a given prompt in a streaming fashion.\n        """\n        request = self.request_queue.add_request(prompt, max_tokens)\n        request_id = request.request_id\n        self._request_outputs[request_id] = deque()\n        last_yielded = 0\n\n        while request.status not in ("COMPLETED", "ERROR"):\n            self._step()\n\n            output_buffer = self._request_outputs.get(request_id, deque())\n            if len(output_buffer) > last_yielded:\n                new_tokens = [output_buffer[i] for i in range(last_yielded, len(output_buffer))]\n                yield self.tokenizer.decode(new_tokens)\n                last_yielded = len(output_buffer)\n\n            time.sleep(0.001)\n\n        # Yield any remaining tokens after the loop finishes\n        output_buffer = self._request_outputs.get(request_id, deque())\n        if output_buffer and len(output_buffer) > last_yielded:\n            final_tokens = [output_buffer[i] for i in range(last_yielded, len(output_buffer))]\n            yield self.tokenizer.decode(final_tokens)\n\n        # Cleanup and error handling\n        if request_id in self._request_outputs:\n            del self._request_outputs[request_id]\n\n        if request.status == "ERROR":\n            raise RuntimeError(f"Request {request_id} failed during processing.")\n\n── pytest failure output ──\n============================= test sessio